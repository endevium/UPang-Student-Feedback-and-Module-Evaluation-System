    "from pathlib import Path\n",
    "import pandas as pd\n",
    "\n",
    "BASE_DIR = Path.cwd()   # current notebook directory\n",
    "DATA_PATH = BASE_DIR / \"data\" / \"feedback_dataset.csv\"\n",
    "\n",
    "df = pd.read_csv(DATA_PATH)\n",
    "\n",
    "# Clean data: remove empty rows and ensure all text is string\n",
    "df = df.dropna(subset=['text', 'label'])  # Remove rows with missing values\n",
    "df['text'] = df['text'].astype(str).str.strip()  # Convert to string and trim whitespace\n",
    "df = df[df['text'] != '']  # Remove empty strings\n",
    "\n",
    "print(f\"Loaded {len(df)} valid feedback samples\")\n",
    "df.head()"
   ]
  },
